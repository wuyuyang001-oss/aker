{
  "name": "aker",
  "productName": "Aker",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Local-first parallel review workbench with real Codex CLI traces and actionable synthesis",
  "main": "main.cjs",
  "scripts": {
    "start": "node server.mjs",
    "test": "node --test test/*.test.mjs",
    "check": "npm test && npm run build:web",
    "build:web": "node build-standalone.mjs",
    "app": "electron .",
    "pack": "node pack.mjs"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "@electron/packager": "^18.3.6"
  },
  "engines": { "node": ">=20" }
}
